# Database
DATABASE_URL=postgresql+asyncpg://chatshare:chatshare_secret@localhost:5432/chatshare_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx,.txt,.png,.jpg,.jpeg,.gif,.zip

# CORS
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
