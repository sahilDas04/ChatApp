# Database
DATABASE_URL=postgresql+asyncpg://chatshare:chatshare_secret@localhost:5432/chatshare_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.xlsx,.txt,.png,.jpg,.jpeg,.gif,.zip

# CORS
# Comma-separated list of exact allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Regex to allow Vercel preview URLs automatically (leave empty to disable)
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
